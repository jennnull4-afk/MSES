# MSES site environment variables (example)
# Copy this to `.env` for local development (do NOT commit real secrets).

# Google Analytics 4 Measurement ID (frontend)
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# Alternative fallback used in some environments (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console verification token
VITE_GSC_VERIFICATION=YOUR_GOOGLE_SITE_VERIFICATION_CODE
# Optional NEXT_PUBLIC fallback
NEXT_PUBLIC_GSC_VERIFICATION=

# Web3Forms API key (server-side secret for contact form)
# IMPORTANT: keep this secret and set it in your deployment environment (Vercel env vars)
WEB3FORMS_ACCESS_KEY=YOUR_WEB3FORMS_ACCESS_KEY

# Notes:
# - Do NOT commit a file containing real secret values to source control.
# - For Vite, environment variables available to the client must be prefixed with VITE_ .
# - For server-side values (like WEB3FORMS_ACCESS_KEY) configure them in your deployment provider.
